  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  steps      EmailCampaignStep[]
  recipients EmailCampaignRecipient[]

  @@index([userId, status])
  @@index([userId, type])
